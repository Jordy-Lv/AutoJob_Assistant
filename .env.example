# Base principal: PostgreSQL.
# Servicio local:
DATABASE_URL=postgresql+psycopg://autojob:autojob@localhost:5432/autojob
# Docker Compose:
# DATABASE_URL=postgresql+psycopg://autojob:autojob@localhost:5433/autojob

# Opcional para futuras integraciones de IA.
OPENAI_API_KEY=
OPENAI_MODEL=

# Fuentes de empleo.
# Estas tres no requieren clave: Remotive, Arbeitnow, RemoteOK.

# Adzuna opcional: https://developer.adzuna.com/
# Al llenar ambas variables, el provider adzuna pasa de missing_api_key a available.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# SerpAPI opcional para Google Jobs: https://serpapi.com/
SERPAPI_KEY=

# Reservado para un provider RapidAPI/JSearch futuro.
RAPIDAPI_KEY=

# Alertas por Telegram (PR 2 — scheduler).
# Crea un bot con @BotFather, copia el token, y obtén tu chat_id (mensaje a @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Búsqueda automática (PR 2).
# SCHEDULER_ENABLED=true|false. Cuando esté en true, las saved_searches habilitadas
# se ejecutan según interval_minutes y notifican vía Telegram las ofertas con score >= ALERT_MIN_SCORE.
SCHEDULER_ENABLED=false
ALERT_MIN_SCORE=70
